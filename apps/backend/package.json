{
  "name": "nearme-backend",
  "version": "0.1.0",
  "private": true,
  "description": "NearMe backend scaffold with NestJS, Prisma, and PostgreSQL",
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "prisma generate",
    "build": "tsc -p tsconfig.build.json",
    "prestart": "prisma generate",
    "start": "prisma migrate deploy && node dist/main.js",
    "start:watch": "tsx watch src/main.ts",
    "start:dev": "npm run build && node dist/main.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node -e \"console.log('No automated tests configured yet')\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:setup": "tsx prisma/setup-db.ts",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/websockets": "^11.1.19",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "prisma": "^7.6.0",
    "@supabase/supabase-js": "^2.103.0",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.2.3",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.0",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
